# Шаблон infra/.env: имена переменных без секретов.
# Реальный .env в git не попадает и обновляется на сервере вручную.

# --- бот ---
OPEN_AI_KEY=
LLM_MODEL=gpt-5.4-mini
TG_BOT_TOKEN=
TG_ADMIN_ID=
ALLOWED_CHAT_IDS=
# На проде ПУСТОЙ — MCP-поиск выключен
RAG_MCP_URL=
SEARCH_CHAT_IDS=
LOG_LEVEL=INFO

# --- деплой (Docker Hub, сервер) ---
DOCKER_USERNAME=
DOCKER_ACCESS_TOKEN=
IMAGE_TAG=latest
HETZNER_SERVER_IP=

# --- S3 cloud.ru (бэкап логов, backup_logs.sh) ---
TENANT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=zheka-bot
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_RETENTION_DAYS=90
